#!/usr/bin/env python3
"""SessionStart hook: env file setup and startup banner.

Called automatically by Claude Code on session start (via .claude/settings.json).
Writes RAPTOR_DIR + PATH to the env file (overwrite, not append) and generates
the startup banner in .startup-output.

The banner is also printed to stdout on purpose: Claude Code attaches
SessionStart stdout to the conversation before the first user message, so the
assistant can render the banner directly without spending a second turn
reading .startup-output back from disk. The file remains as a fallback for
older Claude Code versions and direct/manual callers.

No project env vars are set — the .active symlink is the only source of truth.
"""
import os
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
# ─── trust-marker check (do not import; inline by design) ───
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, str(REPO_ROOT))
import core.startup.process_init  # noqa: E402,F401


def write_env_file():
    """Write the env file with static vars. Overwrites to ensure clean state."""
    env_file = os.environ.get("CLAUDE_ENV_FILE")
    if not env_file:
        return

    repo_root = str(REPO_ROOT)
    bin_dir = str(REPO_ROOT / "bin")

    content = (
        f'export RAPTOR_DIR="{repo_root}"\n'
        f'export PATH="$PATH:{bin_dir}"\n'
    )

    try:
        Path(env_file).write_text(content, encoding="utf-8")
    except OSError:
        pass

    # Set in current process so the doctor check doesn't false-alarm.
    os.environ["RAPTOR_DIR"] = repo_root


def generate_banner():
    """Generate the startup banner and write to .startup-output."""
    try:
        from core.startup.init import main as init_main
        init_main()
    except Exception as e:
        # Non-fatal — write a minimal banner
        output_file = REPO_ROOT / ".startup-output"
        try:
            output_file.write_text(f"RAPTOR startup error: {e}\n")
        except OSError:
            pass


if __name__ == "__main__":
    write_env_file()
    generate_banner()
